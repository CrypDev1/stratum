# RPC endpoints
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Block explorer
BSCSCAN_API_KEY=

# Deployer
PRIVATE_KEY=

# Protocol params (basis points unless noted)
PROTOCOL_FEE_BPS=1000
PROTOCOL_TREASURY=

# Governance / infra (required for a real Deploy.s.sol run)
ADMIN=               # STRAT + protocol admin; MUST equal the deployer EOA at deploy time (roles can be moved after)
SWAP_ROUTER=         # PancakeSwap router adapter
STABLE_TOKEN=        # USDT/USDC on BNB — FeeDistributor reward token

# STRAT distribution targets — fixed 1,000,000,000 hard cap, split 50/30/5/15.
# Amounts are fixed in the deploy script; only these addresses are configurable.
LIQUIDITY_WALLET=    # 50% = 500,000,000 STRAT (manual PancakeSwap LP added later — no liquidity added in any script)
TREASURY_WALLET=     # 15% = 150,000,000 STRAT (locked externally)
TEAM_BENEFICIARY=    #  5% =  50,000,000 STRAT → TeamVesting (3-month cliff, 24-month linear)
EMISSIONS_TARGET=300000000000000000000000000  # 30% = 300,000,000 STRAT, emitted linearly over 365 days (wei)

# ──────────────────────────────────────────────────────────────────────────────
# ADDITIVE INTEGRATION (live mainnet core — chainId 56). Defaults baked into scripts.
# ──────────────────────────────────────────────────────────────────────────────

# Live core addresses (script defaults already point here; override only if needed)
NAV_ORACLE=0xbe263035a704E5039aCaB282AB011DF8175526e3
PROOF_OF_COLLATERAL=0xE28c10B5751bB3E64525fE85951F4A581e253c60
DEPEG_MONITOR=0x7EB90C8F1E8E6bcC0C31A13D37271519dBB50D2a
PORTFOLIO_FACTORY=0x514ff906D211c86685db3DA68B8d18876A1665bd
EMISSIONS_MINTER=0x11e3f4d2c27e37ad7438deac5C143a06381C4816
GAUGE_CONTROLLER=0xacA48e04ce3b7AD51963fE822Cf04dFB362FA6CE

# PancakeSwap V3 SwapRouter on BNB (execution venue for PancakeV3SwapAdapter). This is the V3 SwapRouter
# whose exactInputSingle takes a deadline — NOT the V2 router the factory currently has wired.
PANCAKE_V3_ROUTER=0x1b81D678ffb9C0263b24A97847620C99d213eB14
STABLE_TOKEN=0x55d398326f99059fF775485246999027B3197955  # USDT on BNB (18-dec)

# ── OnboardAssets.s.sol ──
BSTOCK_TOKENS=       # comma-separated bStock token addresses
# PRIMARY source: for bStocks the raw Chainlink SingleFeeds are access-gated (revert for contract callers),
# so price them THROUGH Venus's ResilientOracle (the authorized reader whose main source is that feed).
VENUS_RESILIENT_ORACLE=0x6592b5DE802159F3E74B2486b091D11a8256ab8A
CHAINLINK_FEEDS=     # only for STANDARD aggregators (unused when VENUS_RESILIENT_ORACLE is set)
BSTOCK_POOLS=        # OPTIONAL; omit for Chainlink-only. address(0) entry => Chainlink-only for that asset.
TWAP_WINDOW=1800     # TWAP window (s); optional (only used when a pool is supplied)
MAX_STALENESS=86400  # NAVOracle open-market staleness (s); optional
MAX_CLOSED_STALENESS=604800  # NAVOracle closed-market staleness (s); optional
MAX_DEVIATION_BPS=500        # primary/secondary deviation; optional
MAX_DRIFT_BPS=1000           # after-hours drift bound; optional

# ── ConfigureProtocol.s.sol — Chainlink-only depeg breaker + swap-adapter fee tiers ──
DEPLOY_CHAINLINK_ONLY_DEPEG=true   # deploy ChainlinkOnlyDepegMonitor and wire it into the factory
CHAINLINK_ONLY_DEPEG_MONITOR=      # reuse a prior ChainlinkOnlyDepegMonitor on re-run (idempotency)
# Per-pair V3 fee tiers for the swap adapter (STABLE<->token). NVDAB/USDT is the 0.05% (500) tier.
SWAP_POOL_FEE_TOKENS=0x02Fca66C1D1aFB4E2A7884261eB00F63598a7436,0xbe9D156892E55e7154BcD3cB0FEA677F9D3103E1
SWAP_POOL_FEE_TIERS=500,2500

# ── CreateTitans.s.sol — the launch index "Titans" (TTAN), a ZERO-FEE auto-rebalancing Index ──
# Basket: NVDAB 40% / SPCXB 60% (SPCXB-heavy to route mints through its deep pool; NVDAB's is thin).
# (TSLAB dropped: its only V3 pool has zero liquidity => un-mintable.)
INDEX_COMPONENTS=0x02Fca66C1D1aFB4E2A7884261eB00F63598a7436,0xbe9D156892E55e7154BcD3cB0FEA677F9D3103E1
INDEX_WEIGHTS=4000,6000
INDEX_NAME=Titans
INDEX_SYMBOL=TTAN
# No management fee — Index portfolios are rules-based and fee-free (fees are a Vault-only feature).
MAX_SLIPPAGE_BPS=500       # per-swap bound. NOTE: NVDAB's thin pool still slips ~6% on a ~$40 leg, so a
                           # 100-USDT mint needs a higher bound OR deeper NVDAB LP (see report).
REBALANCE_TOLERANCE_BPS=100
MAX_TRADE_BPS=5000

# Earn (Priority 2) — set either/both to deploy a standalone Earn YieldRouter
VENUS_VTOKEN=        # Venus vToken market for STABLE_TOKEN (e.g. vUSDT = 0xfD5840Cd36d94D7229439859C0112a4185BC0255)
LISTA_VAULT=         # Lista ERC-4626 vault for STABLE_TOKEN (confirm it is 4626)
LISTA_APR_BPS=       # initial reported APR for the Lista adapter (keeper updates later)
BLOCKS_PER_YEAR=10512000  # BSC blocks/year for Venus APR annualization (~3s blocks)
EARN_IDLE_BUFFER_BPS=1000 # YieldRouter idle buffer

# ── Stratum Earn ERC-4626 module (script/DeployEarn.s.sol) — additive; reuses VENUS_VTOKEN/LISTA_VAULT above.
# The DeployEarn signer must equal ADMIN at deploy time (same convention as Deploy.s.sol) so the script can
# attach the initial strategy in-run. Venus is attached first if both venues are set; Lista is a migration target.
EARN_VAULT_NAME=Stratum Earn USDT   # share token name for the first Earn vault
EARN_VAULT_SYMBOL=eUSDT             # share token symbol
LISTA_UNDERLYING_WHALE=             # (fork tests only) holder of the Lista vault's underlying for EarnFork.t.sol

# Perp (Priority 3) — set PERP_MARKET to deploy LiquidityPool + PerpEngine
PERP_MARKET=         # the asset whose live NAV is the perp mark price (a bStock)
POOL_SEED_AMOUNT=    # stable units to seed the LP counterparty (SeedPerp.s.sol)
INSURANCE_SEED_AMOUNT=  # stable units to seed the insurance fund (SeedPerp.s.sol)
PERP_LIQUIDITY_POOL= # reuse a prior LiquidityPool on re-run (idempotency)
PERP_ENGINE=         # reuse a prior PerpEngine on re-run (idempotency)

# Leverage (Priority 2/3) — set to deploy a LeverageModule over a portfolio
LEVERAGE_PORTFOLIO=  # the Index/Vault portfolio used as collateral
LEVERAGE_MODULE=     # reuse a prior LeverageModule on re-run (idempotency)

# Gauge creation (CreateGauge.s.sol)
GAUGE=               # portfolio address to register as a gauge

# Gauge emissions distributor (ConfigureProtocol stage 5)
STRAT=0xf0C2705Cb380c37FA92EEBD9301e13496D859906  # reward token (live)
GAUGE_DISTRIBUTOR=   # reuse a prior GaugeDistributor on re-run (idempotency)

# ConfigureProtocol.s.sol reuse vars (set to prior-run outputs to skip redeploy)
SWAP_ADAPTER=
EARN_YIELD_ROUTER=

# Keepers (off-chain; see keepers/README.md)
EMISSIONS_RECIPIENT= # set to the GaugeDistributor address for per-gauge splitting (else GAUGE_CONTROLLER)
# GAUGE_DISTRIBUTOR (above) — if set, the emissions keeper calls distribute() after minting
ASSETS=              # comma-separated bStock addresses for the market-status keeper
# Forked-mainnet test harness (optional)
FORK_RPC=
VENUS_UNDERLYING_WHALE=
